---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'work'>;
}

const { project } = Astro.props;
const { title, tags, year, thumbnail, featured } = project.data;
const slug = project.id;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Stable unique ID for the SVG clipPath (slug is URL-safe)
const clipId = `clip-${slug}`;
// Default shape: rounded rectangle in 600×600 space. JS scales to card dimensions via transform.
const DEFAULT_PATH = 'M40,0 H560 Q600,0 600,40 V560 Q600,600 560,600 H40 Q0,600 0,560 V40 Q0,0 40,0 Z';
---

<div class="card-wrapper">
  <!-- Hidden SVG that defines the clip shape for this card -->
  <svg width="0" height="0" style="position:absolute;overflow:hidden" aria-hidden="true">
    <defs>
      <clipPath id={clipId} clipPathUnits="userSpaceOnUse">
        <path class="card-clip-path" d={DEFAULT_PATH} />
      </clipPath>
    </defs>
  </svg>

<article class="project-card" data-featured={featured}>
  <a href={`${base}/work/${slug}/`} class="project-card__link">

    <div class="card-mask" style={`clip-path: url(#${clipId})`}>
      <div class="card-image-wrap">
        <img
          src={thumbnail.src}
          alt={`${title} — project thumbnail`}
          width={thumbnail.width}
          height={thumbnail.height}
          loading="lazy"
          decoding="async"
          class="card-image"
        />
      </div>
      <div class="card-overlay" aria-hidden="true"></div>
      <span class="card-title-overlay" aria-hidden="true">{title}</span>
    </div>

    <div class="project-card__body">

      <h2 class="project-card__title">{title}</h2>

      <div class="project-card__meta">
        <ul class="project-card__tags" role="list" aria-label="Project disciplines">
          {tags.map((tag) => (
            <li class="project-card__tag">{tag}</li>
          ))}
        </ul>
        <time class="project-card__year" datetime={String(year)}>{year}</time>
      </div>

    </div>
  </a>
</article>
</div>

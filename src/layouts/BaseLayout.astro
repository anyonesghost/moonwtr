---
import { getCollection } from 'astro:content';
import NavMenu from '../components/NavMenu.astro';
import '../styles/global 3.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio — Selected Work',
  description = 'Creative portfolio — selected work in branding, editorial, and motion.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allProjects = await getCollection('work');
const projectsData = allProjects.map(p => ({
  title: p.data.title,
  tags: p.data.tags,
  thumbnail: p.data.thumbnail.src,
  href: `${base}/work/${p.id}/`,
}));
const projectsJson = JSON.stringify(projectsData);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/gif" href={`${base}/favicon-animated.gif`} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="shortcut icon" href={`${base}/favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Poppins:wght@900&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>

    <a href="#main-content" class="skip-link">Skip to content</a>

    <div class="page-frame">

      <div class="sticky-cap">

      <header class="top-bar" role="banner">

        <div class="top-bar__nav">
          <NavMenu />
        </div>

        <div class="top-bar__logo" aria-label="JP logo">
          <span class="icon icon--avatar" aria-hidden="true"></span>
        </div>

        <div class="top-bar__social">
          <a href="mailto:mooon.wtr@gmail.com" aria-label="Email">
            <span class="icon icon--email" aria-hidden="true"></span>
          </a>
          <a href="https://www.instagram.com/jaypaul_newhouse_moon.wtr/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <span class="icon icon--instagram" aria-hidden="true"></span>
          </a>
        </div>

        <div class="top-bar__tagline">
          <p>Just a man from Ohio making motion, music,<br/>games, worlds, and machines.</p>
        </div>

        <div class="top-bar__search" data-projects={projectsJson}>

          <div class="top-bar__search-row" id="js-search-row">
            <span class="icon icon--search" aria-hidden="true"></span>
            <div class="top-bar__search-track">
              <div class="top-bar__search-line"></div>
              <button class="top-bar__search-pill" aria-label="Open search" type="button">
                SEARCH
              </button>
              <input
                type="search"
                class="top-bar__search-input"
                id="js-search-input"
                placeholder="TYPE TO SEARCH..."
                aria-label="Search projects"
              />
            </div>
          </div>

          <div class="top-bar__search-row" id="js-filter-row">
            <span class="icon icon--filter" aria-hidden="true"></span>
            <div class="top-bar__search-track">
              <div class="top-bar__search-line"></div>
              <button class="top-bar__search-pill" aria-label="Filter projects" type="button" id="js-filter-btn">
                FILTER
              </button>
            </div>
          </div>

          <!-- Search dropdown -->
          <div class="search-dropdown" id="js-search-dropdown" role="listbox" aria-label="Search results">
            <ul class="search-dropdown__list" id="js-search-results"></ul>
          </div>

        </div>

      </header>

      <!-- ─── Filter strip ──────────────────────────────────────── -->
      <div class="filter-strip" id="js-filter-strip" aria-hidden="true">
        <div class="filter-strip__inner">
          {['ALL', '3D', 'GAME', 'BUILD', 'VIDEO'].map(tag => (
            <button
              class={`filter-strip__tag${tag === 'ALL' ? ' is-active' : ''}`}
              data-filter={tag.toLowerCase()}
              type="button"
            >{tag}</button>
          ))}
        </div>
      </div>

      </div><!-- /.sticky-cap -->

      <slot />

      <footer class="site-footer" role="contentinfo">
        <div class="site-footer__inner">
          <small class="site-footer__copy">
            &copy; {new Date().getFullYear()} Jay Paul Newhouse
          </small>
          <nav class="footer-nav" aria-label="Footer navigation">
            <ul class="footer-nav__list" role="list">
              <li>
                <a
                  href="https://www.instagram.com/jaypaul_newhouse_moon.wtr/"
                  class="footer-nav__link"
                  rel="noopener noreferrer"
                  target="_blank"
                >Instagram</a>
              </li>
            </ul>
          </nav>
        </div>
      </footer>

    </div><!-- /.page-frame -->

  </body>

<script>
  // ── Project data (embedded at build time) ────────────────────────────────────
  interface ProjectEntry {
    title: string;
    tags: string[];
    thumbnail: string;
    href: string;
  }

  const searchContainer = document.querySelector<HTMLElement>('.top-bar__search');
  const projects: ProjectEntry[] = JSON.parse(searchContainer?.dataset.projects ?? '[]');

  // ── DOM refs ─────────────────────────────────────────────────────────────────
  const searchRow      = document.getElementById('js-search-row');
  const searchInput    = document.getElementById('js-search-input') as HTMLInputElement | null;
  const searchDropdown = document.getElementById('js-search-dropdown');
  const searchResults  = document.getElementById('js-search-results');
  const gridItems      = document.querySelectorAll<HTMLElement>('.project-grid__item');

  // ── Grid filter (homepage only — no-ops when grid absent) ────────────────────
  function filterGridByTitle(query: string) {
    gridItems.forEach(item => {
      const title = item.querySelector('.project-card__title')?.textContent?.toLowerCase() ?? '';
      item.hidden = query.length > 0 && !title.includes(query);
    });
  }

  // ── Dropdown ─────────────────────────────────────────────────────────────────
  function showDropdown(query: string) {
    if (!searchDropdown || !searchResults) return;

    if (query.length === 0) {
      hideDropdown();
      return;
    }

    const matches = projects
      .filter(p => {
        const q = query.toLowerCase();
        return p.title.toLowerCase().includes(q) || p.tags.some(t => t.toLowerCase().includes(q));
      })
      .slice(0, 5);

    if (matches.length === 0) {
      hideDropdown();
      return;
    }

    searchResults.innerHTML = matches.map(p => `
      <li>
        <a class="search-dropdown__item" href="${p.href}">
          <img class="search-dropdown__thumb" src="${p.thumbnail}" alt="" width="40" height="40" />
          <div class="search-dropdown__info">
            <span class="search-dropdown__title">${p.title}</span>
            <span class="search-dropdown__tags">${p.tags.join(', ')}</span>
          </div>
        </a>
      </li>
    `).join('');

    searchDropdown.classList.add('is-visible');
  }

  function hideDropdown() {
    searchDropdown?.classList.remove('is-visible');
    if (searchResults) searchResults.innerHTML = '';
  }

  // ── Search row interaction ────────────────────────────────────────────────────
  if (searchRow && searchInput) {
    const searchPill = searchRow.querySelector<HTMLButtonElement>('.top-bar__search-pill')!;

    function openSearch() {
      searchRow!.classList.add('is-searching');
      searchInput!.focus();
    }

    function closeSearch() {
      searchRow!.classList.remove('is-searching');
      searchInput!.value = '';
      filterGridByTitle('');
      hideDropdown();
    }

    searchPill.addEventListener('click', openSearch);
    searchRow.addEventListener('click', (e) => {
      if (e.target !== searchInput) openSearch();
    });

    searchInput.addEventListener('input', () => {
      const query = searchInput!.value.trim().toLowerCase();
      filterGridByTitle(query);
      showDropdown(query);
    });

    searchInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeSearch();
    });

    document.addEventListener('click', (e: MouseEvent) => {
      const target = e.target as Node;
      const outsideSearch = !searchRow.contains(target);
      const outsideDropdown = !searchDropdown?.contains(target);
      if (outsideSearch && outsideDropdown) {
        if (searchRow.classList.contains('is-searching')) closeSearch();
        else hideDropdown();
      }
    });
  }

  // ── Tag filter strip (runs on every page, no-ops when no grid) ───────────────
  const filterBtn   = document.getElementById('js-filter-row');
  const filterStrip = document.getElementById('js-filter-strip');

  filterBtn?.addEventListener('click', () => {
    const isOpen = filterStrip?.classList.toggle('is-open');
    filterStrip?.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
  });

  filterStrip?.querySelectorAll<HTMLButtonElement>('.filter-strip__tag').forEach(btn => {
    btn.addEventListener('click', () => {
      filterStrip!.querySelectorAll('.filter-strip__tag').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const filter = btn.dataset.filter!;
      gridItems.forEach(item => {
        const tags = item.dataset.tags ?? '';
        const visible = filter === 'all' || tags.split(',').includes(filter);
        item.style.display = visible ? '' : 'none';
      });
    });
  });

  // ── Deep-link filter on page load ────────────────────────────────────────
  const urlFilter = new URLSearchParams(window.location.search).get('filter');
  if (urlFilter && filterStrip) {
    const matchBtn = filterStrip.querySelector<HTMLButtonElement>(
      `.filter-strip__tag[data-filter="${urlFilter}"]`
    );
    if (matchBtn) {
      filterStrip.classList.add('is-open');
      filterStrip.setAttribute('aria-hidden', 'false');
      filterStrip.querySelectorAll('.filter-strip__tag').forEach(b => b.classList.remove('is-active'));
      matchBtn.classList.add('is-active');
      gridItems.forEach(item => {
        const tags = item.dataset.tags ?? '';
        const visible = urlFilter === 'all' || tags.split(',').includes(urlFilter);
        item.style.display = visible ? '' : 'none';
      });
    }
  }
</script>
</html>

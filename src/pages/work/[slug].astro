---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  const sorted = projects.sort((a, b) => b.data.year - a.data.year);
  const len = sorted.length;
  return sorted.map((project, i) => ({
    params: { slug: project.id },
    props: {
      project,
      prevProject: sorted[(i - 1 + len) % len],
      nextProject: sorted[(i + 1) % len],
    },
  }));
}

const { project, prevProject, nextProject } = Astro.props;
const { title, tags, year, thumbnail, description, externalUrl, intention, decisions, processImages, thread } = project.data;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function getCtaLabel(tags: string[]): string {
  const lower = tags.map(t => t.toLowerCase());
  if (lower.includes('game')) return 'PLAY →';
  if (lower.includes('film') || lower.includes('motion')) return 'WATCH →';
  return 'VIEW →';
}
const ctaLabel = getCtaLabel(tags);
---

<BaseLayout title={`${title} — Moon.WTR`} description={description}>

  <!-- ─── Project nav bar ─────────────────────────────────────── -->
  <nav class="project-nav-bar" aria-label="Project navigation">

    <a href={`${base}/work/${prevProject.id}/`} class="project-nav-bar__section project-nav-bar__section--prev">
      <span class="project-nav-bar__label">← Previous Project</span>
      <span class="project-nav-bar__title">{prevProject.data.title}</span>
    </a>

    <a href={`${base}/`} class="project-nav-bar__section project-nav-bar__section--home">
      <span class="project-nav-bar__home">Home</span>
    </a>

    <a href={`${base}/work/${nextProject.id}/`} class="project-nav-bar__section project-nav-bar__section--next">
      <span class="project-nav-bar__label">Next Project →</span>
      <span class="project-nav-bar__title">{nextProject.data.title}</span>
    </a>

  </nav>

  <main id="main-content">

    <!-- ─── Hero ────────────────────────────────────────────────── -->
    <section class="project-hero" aria-label={`${title} hero`}>
      <div class="project-hero__media">
        <img
          src={thumbnail.src}
          alt={`${title} — hero image`}
          width={thumbnail.width}
          height={thumbnail.height}
          class="project-hero__img"
          decoding="async"
          data-lightbox-src={thumbnail.src}
          data-lightbox-alt={`${title} — full image`}
          id="js-hero-img"
        />
        <div class="project-hero__gradient" aria-hidden="true"></div>
        <span class="project-hero__expand-hint" aria-hidden="true">[ EXPAND ]</span>
      </div>
      <div class="project-hero__title-wrap">
        <h1 class="project-hero__title">{title}</h1>
      </div>
    </section>

    <!-- ─── Section 1: The Hook ──────────────────────────────────── -->
    {description && (
      <section class="project-hook" aria-label="Description">
        <p class="project-hook__text">{description}</p>
      </section>
    )}

    <!-- ─── Sections 2–6 + nav ───────────────────────────────────── -->
    <div class="project-bts">

      <!-- ─── Section 2: The Intention ─────────────────────────── -->
      {intention && (
        <section class="project-bts__section" aria-label="The Intention">
          <h2 class="project-bts__label">THE INTENTION</h2>
          <p class="project-bts__body">{intention}</p>
        </section>
      )}

      <!-- ─── Section 3: The Decisions ─────────────────────────── -->
      {decisions && decisions.length > 0 && (
        <section class="project-bts__section" aria-label="The Decisions">
          <h2 class="project-bts__label">THE DECISIONS</h2>
          <ul class="project-decisions" role="list">
            {decisions.map(d => (
              <li class="project-decision">
                <h3 class="project-decision__label">{d.label}</h3>
                <p class="project-decision__body">{d.body}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- ─── Section 4: The Process ───────────────────────────── -->
      {processImages && processImages.length > 0 && (
        <section class="project-bts__section" aria-label="The Process">
          <h2 class="project-bts__label">THE PROCESS</h2>
          <ul class="project-process-grid" role="list">
            {processImages.map((img, i) => (
              <li>
                <img
                  src={img.src}
                  alt={`${title} — process image ${i + 1}`}
                  width={img.width}
                  height={img.height}
                  class="project-process-img js-lightbox-trigger"
                  data-lightbox-src={img.src}
                  data-lightbox-alt={`${title} — process ${i + 1}`}
                  decoding="async"
                  loading="lazy"
                />
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- ─── Section 5: The Result ─────────────────────────────── -->
      <section class="project-bts__section project-bts__section--result" aria-label="The Result">
        <h2 class="project-bts__label">THE RESULT</h2>
        <div class="project-result">
          <img
            src={thumbnail.src}
            alt={`${title} — final image`}
            width={thumbnail.width}
            height={thumbnail.height}
            class="project-result__img js-lightbox-trigger"
            data-lightbox-src={thumbnail.src}
            data-lightbox-alt={`${title} — full image`}
            decoding="async"
          />
          <span class="project-result__hint" aria-hidden="true">[ EXPAND ]</span>
          {externalUrl && (
            <a
              href={externalUrl}
              class="project-result__cta"
              target="_blank"
              rel="noopener noreferrer"
            >{ctaLabel}</a>
          )}
        </div>
      </section>

      <!-- ─── Section 6: The Thread ─────────────────────────────── -->
      {thread && (
        <section class="project-thread" aria-label="The Thread">
          <p class="project-thread__text">{thread}</p>
        </section>
      )}

      <!-- ─── Navigation ───────────────────────────────────────── -->
      <nav class="project-nav" aria-label="Project navigation">
        <a href={`${base}/`} class="project-nav__link project-nav__link--back">← BACK TO WORK</a>
        {nextProject && (
          <a href={`${base}/work/${nextProject.id}/`} class="project-nav__link project-nav__link--next">
            NEXT PROJECT →
          </a>
        )}
      </nav>

    </div><!-- /.project-bts -->

  </main>

</BaseLayout>

<script>
  // ── Hero entrance animation ────────────────────────────────────────────────
  const hero = document.querySelector<HTMLElement>('.project-hero');
  if (hero) {
    hero.classList.add('is-entering');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        hero.classList.remove('is-entering');
        hero.classList.add('has-entered');
      });
    });
  }

  // ── Lightbox ───────────────────────────────────────────────────────────────
  const lightbox = document.createElement('div');
  lightbox.id = 'js-lightbox';
  lightbox.setAttribute('aria-modal', 'true');
  lightbox.setAttribute('role', 'dialog');
  lightbox.setAttribute('aria-label', 'Image lightbox');
  lightbox.innerHTML = `
    <button class="lightbox__close" id="js-lightbox-close" aria-label="Close lightbox">✕</button>
    <img class="lightbox__img" id="js-lightbox-img" alt="" />
  `;
  document.body.appendChild(lightbox);

  const lbImg   = lightbox.querySelector<HTMLImageElement>('#js-lightbox-img')!;
  const lbClose = lightbox.querySelector<HTMLButtonElement>('#js-lightbox-close')!;

  function openLightbox(src: string, alt: string) {
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  // Hero img + all .js-lightbox-trigger elements share the same lightbox
  document.querySelectorAll<HTMLElement>('#js-hero-img, .js-lightbox-trigger').forEach(el => {
    el.style.cursor = 'zoom-in';
    el.addEventListener('click', () => {
      const src = el.dataset.lightboxSrc ?? (el as HTMLImageElement).src;
      const alt = el.dataset.lightboxAlt ?? (el as HTMLImageElement).alt;
      openLightbox(src, alt);
    });
  });

  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('is-open')) closeLightbox();
  });
</script>

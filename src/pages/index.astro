---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProjects = await getCollection('work');
const projects = allProjects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.year - a.data.year;
});
---

<BaseLayout>

  <!-- ─── Hero section ────────────────────────────────────────── -->
  <section class="hero-section" aria-label="Site title">
    <h1 class="hero-heading">
      <span class="hero-heading__serif">MOON.</span><span class="hero-heading__sans">WTR</span>
    </h1>
    <p class="hero-tagline">It's kinda like magic</p>
  </section>

  <!-- ─── Main content ────────────────────────────────────────── -->
  <main id="main-content" class="site-main">

    <!-- ─── Work section ──────────────────────────────────────── -->
    <section class="work-section" aria-label="Work projects">

      <header class="work-section__header">
        <h2 class="work-section__heading sr-only">Projects</h2>
      </header>

      <!-- Project grid -->
      {projects.length > 0 ? (
        <ul class="project-grid" role="list">
          {projects.map((project, index) => (
            <li
              class="project-grid__item"
              role="listitem"
              data-tags={project.data.tags.map(t => t.toLowerCase()).join(',')}
              style={`--card-delay: ${index * 100}ms`}
            >
              <ProjectCard project={project} />
            </li>
          ))}
        </ul>
      ) : (
        <p class="project-grid__empty">
          No projects yet. Add <code>.md</code> files to{' '}
          <code>src/content/work/</code>.
        </p>
      )}

    </section>

  </main>

</BaseLayout>

<script>
  // ── Remove entrance animation after first play ──────────────────────────────
  const items = document.querySelectorAll<HTMLLIElement>('.project-grid__item');
  items.forEach(item => {
    item.addEventListener('animationend', () => {
      item.style.animationName = 'none';
    }, { once: true });
  });

  // ── Proximity image drift on cards ───────────────────────────────────────
  // Drift targets .card-image-wrap (translation only).
  // .card-image handles counter-rotation via CSS independently.
  const DRIFT_RADIUS = 400;
  const DRIFT_STRENGTH = 0.08;

  interface CardEntry {
    wrapper: HTMLElement;
    wrap: HTMLElement; // .card-image-wrap — JS target for drift
  }

  const allWrappers = Array.from(document.querySelectorAll<HTMLElement>('.card-wrapper'));

  const cardEntries: CardEntry[] = allWrappers.map(wrapper => ({
    wrapper,
    wrap: wrapper.querySelector<HTMLElement>('.card-image-wrap')!,
  })).filter(e => e.wrap !== null);

  let rafId: number | null = null;
  let mouseX = 0;
  let mouseY = 0;

  document.addEventListener('mousemove', (e: MouseEvent) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    if (rafId === null) {
      rafId = requestAnimationFrame(updateDrift);
    }
  });

  function updateDrift() {
    rafId = null;

    cardEntries.forEach(({ wrapper, wrap }) => {
      const rect = wrapper.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;

      const dx = mouseX - cx;
      const dy = mouseY - cy;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < DRIFT_RADIUS) {
        const strength = 1 - dist / DRIFT_RADIUS;
        const driftX = dx * DRIFT_STRENGTH * strength;
        const driftY = dy * DRIFT_STRENGTH * strength;
        wrap.style.transition = 'none';
        wrap.style.transform = `translate(calc(-50% + ${driftX}px), calc(-50% + ${driftY}px))`;
      } else {
        wrap.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
        wrap.style.transform = 'translate(-50%, -50%)';
      }
    });
  }

  document.addEventListener('mouseleave', () => {
    cardEntries.forEach(({ wrap }) => {
      wrap.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      wrap.style.transform = 'translate(-50%, -50%)';
    });
  });

  // ── Neighbor spring physics ───────────────────────────────────────────────
  const neighborTimeouts = new Map<HTMLElement, ReturnType<typeof setTimeout>[]>();

  allWrappers.forEach(wrapper => {
    wrapper.addEventListener('mouseenter', () => {
      const hovRect = wrapper.getBoundingClientRect();
      const hovCx = hovRect.left + hovRect.width / 2;
      const hovCy = hovRect.top + hovRect.height / 2;

      allWrappers.forEach(other => {
        if (other === wrapper) return;

        // Clear any in-flight timeouts for this neighbor
        (neighborTimeouts.get(other) ?? []).forEach(clearTimeout);

        const oRect = other.getBoundingClientRect();
        const oCx = oRect.left + oRect.width / 2;
        const oCy = oRect.top + oRect.height / 2;

        const dx = oCx - hovCx;
        const dy = oCy - hovCy;
        const pixelDist = Math.sqrt(dx * dx + dy * dy);
        const nx = dx / pixelDist;
        const ny = dy / pixelDist;

        // Grid distance: pixel distance / card width ≈ number of columns away
        const gridDist = pixelDist / hovRect.width;
        const strength = 1 / (gridDist + 1);
        const push = 18 * strength;
        const overshoot = -6 * strength;

        // Phase 1 (0ms): push away
        other.style.transition = 'transform 150ms ease-out';
        other.style.transform = `translate(${nx * push}px, ${ny * push}px)`;

        // Phase 2 (150ms): overshoot back past zero
        const t1 = setTimeout(() => {
          other.style.transition = 'transform 200ms ease-out';
          other.style.transform = `translate(${nx * overshoot}px, ${ny * overshoot}px)`;
        }, 150);

        // Phase 3 (350ms): settle to rest
        const t2 = setTimeout(() => {
          other.style.transition = 'transform 150ms ease-in-out';
          other.style.transform = 'translate(0, 0)';
        }, 350);

        neighborTimeouts.set(other, [t1, t2]);
      });
    });

    wrapper.addEventListener('mouseleave', () => {
      allWrappers.forEach(other => {
        if (other === wrapper) return;
        (neighborTimeouts.get(other) ?? []).forEach(clearTimeout);
        neighborTimeouts.delete(other);
        other.style.transition = 'transform 200ms ease';
        other.style.transform = 'translate(0, 0)';
      });
    });
  });

  // ── SVG clipPath morphing ─────────────────────────────────────────────────
  import { interpolate as flubberInterpolate } from 'flubber';

  // Tokenize an SVG path and divide every numeric value by 600,
  // normalising 600×600 coordinates to objectBoundingBox (0–1) space.
  function normalizePath(d: string): string {
    const re = /([MmZzLlHhVvCcSsQqTtAa])|(-?(?:\d+\.?\d*|\.\d+)(?:[eE][+-]?\d+)?)/g;
    const parts: string[] = [];
    let m: RegExpExecArray | null;
    while ((m = re.exec(d)) !== null) {
      if (m[1]) {
        parts.push(m[1]);
      } else if (m[2] !== undefined) {
        parts.push((parseFloat(m[2]) / 600).toFixed(8));
      }
    }
    return parts.join(' ');
  }

  const MASK_SHAPES_RAW = [
    // Shy Guy
    'M225.04,365.8H.52S-7.35,215.9,72.11,108.02C116.4,47.89,187.81.81,302.82.01c116.32-.81,187.27,46.89,230.46,108.08,76.13,107.88,65.97,257.71,65.97,257.71h-217.4v177.32s-1.25,56.88-79.03,56.88-78.16-56.86-78.16-56.86l.38-177.34Z',
    // Easy Ease
    'M562.45,0H38.06v52.15s126.03,143.41,126.03,263.64-126.53,227.43-126.53,227.43v56.78h507.51v-56.78s-112.99-95.61-112.99-228.88S562.45,52.15,562.45,52.15V0Z',
    // Ease Out
    'M569.04,0h-243.15l-131.13,135.64-68.29,70.63-95.51,98.79,98.9,98.9,65.46,65.46,130.58,130.58h243.15v-88.93s-121.58-136.21-121.58-211.07,121.58-206.57,121.58-206.57V0Z',
    // Ease In
    'M30.96,0h243.15l131.13,135.64,68.29,70.63,95.51,98.79-98.9,98.9-65.46,65.46-130.58,130.58H30.96v-88.93s121.58-136.21,121.58-211.07S30.96,93.43,30.96,93.43V0Z',
    // Direct Selection
    'M594.11,171.99l-6.79-6.79-8.37-8.37-213.25-54.3-178.82-45.54L5.89,9.42l51.49,177.83,50.64,190.88,52.34,197.28,8.15,8.15,7.01,7.01,62.04-62.04s55.26-134.79,107.49-187.01c52.23-52.23,183.87-104.35,183.87-104.35l65.18-65.18Z',
  ];

  const DEFAULT_SHAPE_RAW = 'M40,0 H560 Q600,0 600,40 V560 Q600,600 560,600 H40 Q0,600 0,560 V40 Q0,0 40,0 Z';

  const normalizedShapes = MASK_SHAPES_RAW.map(normalizePath);
  const normalizedDefault = normalizePath(DEFAULT_SHAPE_RAW);

  // DEBUG 4: confirm coordinates are in 0-1 range
  console.log('[morph] normalizedDefault (first 80 chars):', normalizedDefault.slice(0, 80));
  console.log('[morph] normalizedShapes[0] (first 80 chars):', normalizedShapes[0].slice(0, 80));

  interface MorphCard {
    pathEl: SVGPathElement;
    current: string;
    lastIdx: number;
    rafId: number | null;
  }

  function easeInOut(t: number): number {
    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
  }

  function morphTo(card: MorphCard, target: string, duration: number) {
    if (card.rafId !== null) cancelAnimationFrame(card.rafId);

    const from = card.current;
    const interp = flubberInterpolate(from, target, { maxSegmentLength: 4 });
    const start = performance.now();

    function step(now: number) {
      const raw = Math.min((now - start) / duration, 1);
      const d = interp(easeInOut(raw));
      card.pathEl.setAttribute('d', d);
      card.current = d;
      if (raw < 1) {
        card.rafId = requestAnimationFrame(step);
      } else {
        card.rafId = null;
        card.current = target;
      }
    }
    card.rafId = requestAnimationFrame(step);
  }

  const morphCards: MorphCard[] = [];
  allWrappers.forEach(wrapper => {
    const pathEl = wrapper.querySelector<SVGPathElement>('clipPath path');

    // DEBUG 3: confirm clip-path is applied and path element found
    const mask = wrapper.querySelector<HTMLElement>('.card-mask');
    console.log('[morph] card-mask clip-path style:', mask?.style.clipPath ?? 'NONE');
    console.log('[morph] clipPath path element found:', !!pathEl, pathEl?.getAttribute('d')?.slice(0, 40));

    if (!pathEl) return;
    const card: MorphCard = { pathEl, current: normalizedDefault, lastIdx: -1, rafId: null };
    morphCards.push(card);

    wrapper.addEventListener('mouseenter', () => {
      let idx: number;
      do { idx = Math.floor(Math.random() * normalizedShapes.length); }
      while (normalizedShapes.length > 1 && idx === card.lastIdx);
      card.lastIdx = idx;
      morphTo(card, normalizedShapes[idx], 500);
    });

    wrapper.addEventListener('mouseleave', () => {
      morphTo(card, normalizedDefault, 400);
    });
  });
</script>

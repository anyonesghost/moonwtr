---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import NavMenu from '../components/NavMenu.astro';
import '../styles/global 3.css';

const allProjects = await getCollection('work');
const projects = allProjects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.year - a.data.year;
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Creative portfolio — selected work in branding, editorial, and motion."
    />
    <title>Portfolio — Selected Work</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>

    <!-- ─── Skip link (accessibility) ──────────────────────────── -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- ─── Main content ────────────────────────────────────────── -->
    <main id="main-content" class="site-main">

      <!-- Hero / intro -->
      <section class="intro-section" aria-label="Introduction">
        <div class="intro-section__inner">
          <div class="intro-row">
            <NavMenu />
            <h1 class="intro-heading">
              <span class="intro-heading__serif">MOON.</span><span class="intro-heading__sans">WTR</span>
            </h1>
          </div>

          <p class="intro-body">
            Motion, music, games, and machines — made by hand in Ohio.
          </p>
        </div>
      </section>

      <!-- ─── Work section ──────────────────────────────────────── -->
      <section class="work-section" aria-label="Work projects">

        <header class="work-section__header">
          <h2 class="work-section__heading sr-only">Projects</h2>
        </header>

        <!-- Filter bar -->
        <nav class="filter-bar" aria-label="Filter by discipline">
          <ul class="filter-bar__list" role="list">
            <li>
              <button
                class="filter-bar__btn is-active"
                data-filter="all"
                aria-pressed="true"
              >All</button>
            </li>
            <li>
              <button
                class="filter-bar__btn"
                data-filter="game"
                aria-pressed="false"
              >Game</button>
            </li>
            <li>
              <button
                class="filter-bar__btn"
                data-filter="film"
                aria-pressed="false"
              >Film</button>
            </li>
            <li>
              <button
                class="filter-bar__btn"
                data-filter="build"
                aria-pressed="false"
              >Build</button>
            </li>
          </ul>
        </nav>

        <!-- Project grid -->
        {projects.length > 0 ? (
          <ul class="project-grid" role="list">
            {projects.map((project, index) => (
              <li
                class="project-grid__item"
                role="listitem"
                data-tags={project.data.tags.map(t => t.toLowerCase()).join(',')}
                style={`--card-delay: ${index * 100}ms`}
              >
                <ProjectCard project={project} />
              </li>
            ))}
          </ul>
        ) : (
          <p class="project-grid__empty">
            No projects yet. Add <code>.md</code> files to{' '}
            <code>src/content/work/</code>.
          </p>
        )}

      </section>

    </main>

    <!-- ─── Site footer ─────────────────────────────────────────── -->
    <footer class="site-footer" role="contentinfo">
      <div class="site-footer__inner">

        <small class="site-footer__copy">
          &copy; {new Date().getFullYear()} Jay Paul Newhouse
        </small>

        <nav class="footer-nav" aria-label="Footer navigation">
          <ul class="footer-nav__list" role="list">
            <li>
              <a
                href="https://linkedin.com"
                class="footer-nav__link"
                rel="noopener noreferrer"
                target="_blank"
              >LinkedIn</a>
            </li>
            <li>
              <a
                href="https://instagram.com"
                class="footer-nav__link"
                rel="noopener noreferrer"
                target="_blank"
              >Instagram</a>
            </li>
          </ul>
        </nav>

      </div>
    </footer>

  </body>
</html>

<script>
  // ── Filter keywords per category ───────────────────────────────────────
  const filterMap: Record<string, string[]> = {
    game:  ['game', 'web', 'narrative'],
    film:  ['film', 'motion', 'lore'],
    build: ['build', 'wrap', 'documentation'],
  };

  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-bar__btn');
  const items   = document.querySelectorAll<HTMLLIElement>('.project-grid__item');

  // ── Ensure the last visible card spans full width when alone in a row ──
  function updateWideCard() {
    const visible = [...items].filter(item => !item.hidden);
    visible.forEach(item => item.classList.remove('project-grid__item--wide'));
    if (visible.length % 2 !== 0) {
      visible[visible.length - 1].classList.add('project-grid__item--wide');
    }
  }

  // ── Filter grid by category ────────────────────────────────────────────
  function filterGrid(active: string) {
    items.forEach(item => {
      if (active === 'all') {
        item.hidden = false;
      } else {
        const tags     = (item.dataset.tags ?? '').split(',');
        const keywords = filterMap[active] ?? [];
        item.hidden    = !keywords.some(k => tags.some(t => t.includes(k)));
      }
    });
    updateWideCard();
  }

  // ── Filter button click ────────────────────────────────────────────────
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('is-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');
      filterGrid(btn.dataset.filter ?? 'all');
    });
  });

  // ── Remove entrance animation after first play so filter-show is instant ──
  items.forEach(item => {
    item.addEventListener('animationend', () => {
      item.style.animationName = 'none';
    }, { once: true });
  });

  // ── Set initial wide card ──────────────────────────────────────────────
  updateWideCard();
</script>

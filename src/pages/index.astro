---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProjects = await getCollection('work');
const projects = allProjects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.year - a.data.year;
});
---

<BaseLayout>

  <!-- ─── Hero section ────────────────────────────────────────── -->
  <section class="hero-section" aria-label="Site title">
    <h1 class="hero-heading">
      <span class="hero-heading__serif">MOON.</span><span class="hero-heading__sans">WTR</span>
    </h1>
    <p class="hero-tagline">It's kinda like magic</p>
  </section>

  <!-- ─── Main content ────────────────────────────────────────── -->
  <main id="main-content" class="site-main">

    <!-- ─── Work section ──────────────────────────────────────── -->
    <section class="work-section" aria-label="Work projects">

      <header class="work-section__header">
        <h2 class="work-section__heading sr-only">Projects</h2>
      </header>

      <!-- Project grid -->
      {projects.length > 0 ? (
        <ul class="project-grid" role="list">
          {projects.map((project, index) => (
            <li
              class="project-grid__item"
              role="listitem"
              data-tags={project.data.tags.map(t => t.toLowerCase()).join(',')}
              style={`--card-delay: ${index * 100}ms`}
            >
              <ProjectCard project={project} />
            </li>
          ))}
        </ul>
      ) : (
        <p class="project-grid__empty">
          No projects yet. Add <code>.md</code> files to{' '}
          <code>src/content/work/</code>.
        </p>
      )}

    </section>

  </main>

</BaseLayout>

<script>
  // ── Remove entrance animation after first play ──────────────────────────────
  const items = document.querySelectorAll<HTMLLIElement>('.project-grid__item');
  items.forEach(item => {
    item.addEventListener('animationend', () => {
      item.style.animationName = 'none';
    }, { once: true });
  });

  // ── Grid title filter ───────────────────────────────────────────────────────
  const gridItems = document.querySelectorAll<HTMLLIElement>('.project-grid__item');

  function filterGridByTitle(query: string) {
    gridItems.forEach(item => {
      const title = item.querySelector('.project-card__title')?.textContent?.toLowerCase() ?? '';
      item.hidden = query.length > 0 && !title.includes(query);
    });
  }

  // ── Search row ───────────────────────────────────────────────────────────────
  const searchRow   = document.getElementById('js-search-row');
  const searchInput = document.getElementById('js-search-input') as HTMLInputElement | null;

  if (searchRow && searchInput) {
    const searchPill = searchRow.querySelector<HTMLButtonElement>('.top-bar__search-pill')!;

    function openSearch() {
      searchRow!.classList.add('is-searching');
      searchInput!.focus();
    }

    function closeSearch() {
      searchRow!.classList.remove('is-searching');
      searchInput!.value = '';
      filterGridByTitle('');
    }

    searchPill.addEventListener('click', openSearch);

    searchInput.addEventListener('input', () => {
      filterGridByTitle(searchInput!.value.trim().toLowerCase());
    });

    searchInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeSearch();
    });

    document.addEventListener('click', (e: MouseEvent) => {
      if (!searchRow.contains(e.target as Node) && searchRow.classList.contains('is-searching')) {
        closeSearch();
      }
    });
  }

  // ── Filter row ───────────────────────────────────────────────────────────────
  const filterRow = document.getElementById('js-filter-row');
  if (filterRow) {
    const filterPill = filterRow.querySelector<HTMLButtonElement>('.top-bar__search-pill')!;
    filterPill?.addEventListener('click', () => {
      console.log('Filter clicked — interaction coming soon');
    });
  }

  // ── Proximity magnet effect on card backgrounds ───────────────────────────
  const MAGNET_RADIUS = 200; // px — how close cursor must be to activate
  const MAGNET_STRENGTH = 0.08; // multiplier on displacement

  interface CardEntry {
    wrapper: HTMLElement;
    bg: HTMLElement;
  }

  const cardEntries: CardEntry[] = Array.from(
    document.querySelectorAll<HTMLElement>('.card-wrapper')
  ).map(wrapper => ({
    wrapper,
    bg: wrapper.querySelector<HTMLElement>('.card-magnet-bg')!,
  })).filter(e => e.bg !== null);

  let rafId: number | null = null;
  let mouseX = 0;
  let mouseY = 0;

  document.addEventListener('mousemove', (e: MouseEvent) => {
    mouseX = e.clientX;
    mouseY = e.clientY;

    if (rafId === null) {
      rafId = requestAnimationFrame(updateMagnets);
    }
  });

  function updateMagnets() {
    rafId = null;

    cardEntries.forEach(({ wrapper, bg }) => {
      const rect = wrapper.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;

      const dx = mouseX - cx;
      const dy = mouseY - cy;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < MAGNET_RADIUS) {
        // Disable CSS transition so tracking feels instant
        bg.style.transition = 'opacity 0.2s ease';
        bg.style.opacity = '0.25';
        bg.style.transform = `translate(${dx * MAGNET_STRENGTH}px, ${dy * MAGNET_STRENGTH}px)`;
      } else {
        // Re-enable CSS transition for snap-back and fade out
        bg.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease';
        bg.style.opacity = '0';
        bg.style.transform = 'translate(0, 0)';
      }
    });
  }

  // Reset all on mouse leave
  document.addEventListener('mouseleave', () => {
    cardEntries.forEach(({ bg }) => {
      bg.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease';
      bg.style.opacity = '0';
      bg.style.transform = 'translate(0, 0)';
    });
  });
</script>
